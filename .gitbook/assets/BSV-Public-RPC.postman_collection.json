          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"jsonrpc\": \"1.0\",\n  \"id\": \"getblockchaininfo\",\n  \"method\": \"getblockchaininfo\",\n  \"params\": []\n}"
            },
            "url": { "raw": "{{rpcUrl}}", "host": ["{{rpcUrl}}"] },
            "description": "Returns chain tip, headers, work, prune state, and active soft forks. Cheapest 'is the node alive and on mainnet?' probe."
          },
