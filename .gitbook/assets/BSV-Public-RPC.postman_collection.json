{
  "info": {
    "_postman_id": "f9d6a3e1-2c5b-4c1a-9b71-bsvpublicrpc0001",
    "name": "BSV Public RPC",
    "description": "Most-used SV Node JSON-RPC methods, pre-wired to the public BSV mainnet endpoint at https://bsv-rpc.publicnode.com.\n\nThe endpoint is operated by Allnodes (PublicNode) and powered by the BSV Association as a free, open, unauthenticated entry point to BSV mainnet. It is a shared service: suitable for prototyping, lightweight reads, SPV helpers, and broadcast fallback — not for production custody, deep historical queries, or workloads that need an SLA.\n\nChange the `rpcUrl` collection variable to point at any other public or self-hosted SV Node endpoint without editing individual requests.\n\nDocumentation: see `public-rpc-endpoints.md` in the BSV docs (`network-topology/nodes/sv-node/`).",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "rpcUrl",
      "value": "https://bsv-rpc.publicnode.com",
      "type": "string"
    },
    {
      "key": "sampleBlockHash",
      "value": "00000000000000001d6aeeb079e142a23f820b0727c628d48278406a40df8550",
      "type": "string"
    },
    {
      "key": "sampleTxid",
