                "url": { "raw": "{{rpcUrl}}", "host": ["{{rpcUrl}}"] }
              },
              "status": "OK",
              "code": 200,
              "_postman_previewlanguage": "json",
              "header": [{ "key": "Content-Type", "value": "application/json" }],
              "body": "{\n  \"result\": {\n    \"chain\": \"main\",\n    \"blocks\": 944183,\n    \"headers\": 944183,\n    \"bestblockhash\": \"00000000000000001d6aeeb079e142a23f820b0727c628d48278406a40df8550\",\n    \"difficulty\": 30544825005.71214,\n    \"mediantime\": 1775814943,\n    \"verificationprogress\": 0.9999995916079044,\n    \"pruned\": true,\n    \"pruneheight\": 943800,\n    \"softforks\": [\n      { \"id\": \"bip34\", \"version\": 2, \"reject\": { \"status\": true } },\n      { \"id\": \"bip66\", \"version\": 3, \"reject\": { \"status\": true } },\n      { \"id\": \"bip65\", \"version\": 4, \"reject\": { \"status\": true } },\n      { \"id\": \"csv\",   \"version\": 5, \"reject\": { \"status\": true } }\n    ]\n  },\n  \"error\": null,\n  \"id\": \"getblockchaininfo\"\n}"
